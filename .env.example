# Shared
PROJECT_NAME=find-my-ride

# Database
POSTGRES_DB=find_my_ride
POSTGRES_USER=find_my_ride
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8000
DATABASE_URL=postgresql+psycopg://find_my_ride:change-me-in-prod@db:5432/find_my_ride
SECRET_KEY=replace-with-64-plus-random-characters
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
CORS_ORIGINS=http://localhost:5173
UPLOAD_DIR=/data/uploads
MAX_PHOTOS_PER_RECORD=3
MAX_PHOTO_SIZE_MB=8
MFA_ISSUER=find-my-ride
REFRESH_TOKEN_COOKIE_NAME=fmr_refresh_token
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAMESITE=lax
REFRESH_TOKEN_COOKIE_PATH=/api/auth

# Frontend
FRONTEND_PORT=5173
# For docker-compose.prod.yml, set FRONTEND_PORT to your desired public host port (for example 18080).
VITE_API_URL=/api
VITE_PROXY_TARGET=http://backend:8000
